# Root compose defaults (safe for local self-host / dev)
# Copy to .env to override.

# --- app ports (host) ---
FRONTEND_PORT=3000
BACKEND_PORT=8000

# --- database ---
# Postgres/Redis stay on the internal Compose network by default (no host ports).
# For host-local backend + Compose Postgres only, install.sh applies
# compose.loopback-db.yml (127.0.0.1 publish) and uses POSTGRES_PORT below.
POSTGRES_DB=mission_control
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# --- backend settings (see backend/.env.example for full list) ---
# REQUIRED: Public URL the backend should advertise in generated instructions/webhook flows.
# Update this when the backend is served behind a reverse proxy, custom host, or non-default port.
BASE_URL=http://localhost:8000
# For remote access, set this to your UI origin (e.g. http://<server-ip>:3000 or https://mc.example.com).
CORS_ORIGINS=http://localhost:3000
DB_AUTO_MIGRATE=true
LOG_LEVEL=INFO
REQUEST_LOG_SLOW_MS=1000
AUTH_MODE=local
# REQUIRED when AUTH_MODE=local (must be non-placeholder and at least 50 chars).
# Generate into ignored .env files with: python scripts/ensure_local_auth_env.py
# Placeholder only in this example file — never commit a real token.
LOCAL_AUTH_TOKEN=
# ADR-23 D8: inherited write/action routes must stay hard-disabled.
MUTATIONS_HARD_DISABLED=true

# Slice 3 GitHub adapter (server-only). Leave GITHUB_PAT empty to disable.
# Scope must be exactly {read:project}. See docs/slice-3-github-adapter.md.
GITHUB_PAT=
GITHUB_PROJECT_OWNER=Mhaizza
GITHUB_PROJECT_NUMBER=4
GITHUB_SELF_OWNER=Mhaizza
GITHUB_SELF_REPO=ai-space-colony-sim
GITHUB_MISSION_CONTROL_OWNER=Mhaizza
GITHUB_MISSION_CONTROL_REPO=ai-space-colony-mission-control
GITHUB_POLL_INTERVAL_SECONDS=15
# Fail-closed startup scope/capability probes always run when the adapter is
# enabled (GITHUB_PAT set) and cannot be disabled — there is no bypass.
MC_PRINCIPAL_REGISTRY_JSON=

# --- frontend settings ---
# REQUIRED: Public URL used by the browser to reach the API.
# Use `auto` to target the same host currently serving Mission Control on port 8000.
# Example (explicit override): NEXT_PUBLIC_API_URL=https://mc.example.com
NEXT_PUBLIC_API_URL=auto
